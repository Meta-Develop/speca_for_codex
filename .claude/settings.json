{
  "permissions": {
    "allow": ["Read", "Write", "Glob", "Grep", "Bash(*)"]
  },
  "skills": {
    "project": [".claude/skills"]
  },
  "mcpServers": {
    "serena": {
      "command": "uv",
      "args": [
        "run",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-root",
        "."
      ]
    },
    "semgrep": {
      "command": "npx",
      "args": ["-y", "@semgrep/mcp-server"]
    }
  }
}
