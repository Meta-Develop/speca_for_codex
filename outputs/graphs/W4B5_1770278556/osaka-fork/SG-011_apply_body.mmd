stateDiagram-v2
    direction TB
    [*] --> q_init: block_output = BlockOutput()
    q_init --> q_beacon_roots: process_unchecked_system_transaction(BEACON_ROOTS_ADDRESS, parent_beacon_block_root)
    q_beacon_roots --> q_history: process_unchecked_system_transaction(HISTORY_STORAGE_ADDRESS, parent_hash)
    q_history --> q_iter_tx: for i, tx in enumerate(map(decode_transaction, transactions))
    q_iter_tx --> q_process_tx: process_transaction(block_env, block_output, tx, i)
    q_process_tx --> q_iter_tx: next transaction
    q_iter_tx --> q_withdrawals: all transactions processed
    q_withdrawals --> q_requests: process_withdrawals(block_env, block_output, withdrawals)
    q_requests --> q_return: process_general_purpose_requests(block_env, block_output)
    q_return --> [*]: return block_output
