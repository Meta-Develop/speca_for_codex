stateDiagram-v2
    direction TB
    [*] --> q_check_size: len(rlp.encode(block))
    q_check_size --> q_error_size: size > MAX_RLP_BLOCK_SIZE
    q_error_size --> [*]: raise InvalidBlock
    q_check_size --> q_validate: size <= MAX_RLP_BLOCK_SIZE
    q_validate --> q_check_ommers: validate_header(chain, block.header)
    q_check_ommers --> q_error_ommers: block.ommers != ()
    q_error_ommers --> [*]: raise InvalidBlock
    q_check_ommers --> q_build_env: block.ommers == ()
    q_build_env --> q_apply_body: block_env = vm.BlockEnvironment(...)
    q_apply_body --> q_compute_roots: block_output = apply_body(block_env, transactions, withdrawals)
    q_compute_roots --> q_check_gas: compute state_root, tx_root, receipt_root, bloom, withdrawals_root, requests_hash
    q_check_gas --> q_error_gas: block_output.block_gas_used != block.header.gas_used
    q_error_gas --> [*]: raise InvalidBlock
    q_check_gas --> q_check_tx_root: gas matches
    q_check_tx_root --> q_error_tx: transactions_root != block.header.transactions_root
    q_error_tx --> [*]: raise InvalidBlock
    q_check_tx_root --> q_check_state: tx root matches
    q_check_state --> q_error_state: block_state_root != block.header.state_root
    q_error_state --> [*]: raise InvalidBlock
    q_check_state --> q_check_receipt: state root matches
    q_check_receipt --> q_error_receipt: receipt_root != block.header.receipt_root
    q_error_receipt --> [*]: raise InvalidBlock
    q_check_receipt --> q_check_bloom: receipt root matches
    q_check_bloom --> q_error_bloom: block_logs_bloom != block.header.bloom
    q_error_bloom --> [*]: raise InvalidBlock
    q_check_bloom --> q_check_wd_root: bloom matches
    q_check_wd_root --> q_error_wd: withdrawals_root != block.header.withdrawals_root
    q_error_wd --> [*]: raise InvalidBlock
    q_check_wd_root --> q_check_blob_gas: wd root matches
    q_check_blob_gas --> q_error_blob: block_output.blob_gas_used != block.header.blob_gas_used
    q_error_blob --> [*]: raise InvalidBlock
    q_check_blob_gas --> q_check_requests: blob gas matches
    q_check_requests --> q_error_req: requests_hash != block.header.requests_hash
    q_error_req --> [*]: raise InvalidBlock
    q_check_requests --> q_append: all checks pass
    q_append --> q_prune: chain.blocks.append(block)
    q_prune --> [*]: prune to last 255 blocks if needed
