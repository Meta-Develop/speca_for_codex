stateDiagram-v2
    direction TB
    [*] --> q_parse_deposits: deposit_requests = parse_deposit_requests(block_output)
    q_parse_deposits --> q_check_deposits: requests_from_execution = block_output.requests
    q_check_deposits --> q_append_deposits: len(deposit_requests) > 0
