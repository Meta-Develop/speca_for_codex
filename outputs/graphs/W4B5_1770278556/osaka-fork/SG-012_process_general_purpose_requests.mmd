    q_check_deposits --> q_call_withdrawal: len(deposit_requests) == 0
    q_call_withdrawal --> q_check_wd: system_withdrawal_tx_output = process_checked_system_transaction(WITHDRAWAL_REQUEST_ADDRESS)
    q_check_wd --> q_append_wd: len(return_data) > 0
    q_append_wd --> q_call_consolidation: append WITHDRAWAL_REQUEST_TYPE + return_data
    q_check_wd --> q_call_consolidation: len(return_data) == 0
    q_call_consolidation --> q_check_cons: system_consolidation_tx_output = process_checked_system_transaction(CONSOLIDATION_REQUEST_ADDRESS)
    q_check_cons --> q_append_cons: len(return_data) > 0
    q_append_cons --> [*]: append CONSOLIDATION_REQUEST_TYPE + return_data
    q_check_cons --> [*]: len(return_data) == 0
