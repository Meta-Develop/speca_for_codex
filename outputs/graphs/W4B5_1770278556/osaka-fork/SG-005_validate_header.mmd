stateDiagram-v2
    direction TB
    [*] --> q_check_number: header.number >= 1
    q_check_number --> q_error_num: header.number < 1
    q_error_num --> [*]: raise InvalidBlock
    q_check_number --> q_get_parent: number valid
    q_get_parent --> q_check_excess_blob: parent_header = chain.blocks[-1].header
    q_check_excess_blob --> q_error_blob: header.excess_blob_gas != calculate_excess_blob_gas(parent)
    q_error_blob --> [*]: raise InvalidBlock
    q_check_excess_blob --> q_check_gas_used: excess blob gas valid
    q_check_gas_used --> q_error_gas: header.gas_used > header.gas_limit
    q_error_gas --> [*]: raise InvalidBlock
    q_check_gas_used --> q_check_base_fee: gas used valid
    q_check_base_fee --> q_error_fee: expected_base_fee != header.base_fee_per_gas
    q_error_fee --> [*]: raise InvalidBlock
    q_check_base_fee --> q_check_time: base fee valid
    q_check_time --> q_error_time: header.timestamp <= parent_header.timestamp
    q_error_time --> [*]: raise InvalidBlock
    q_check_time --> q_check_seq: timestamp valid
    q_check_seq --> q_error_seq: header.number != parent_header.number + 1
    q_error_seq --> [*]: raise InvalidBlock
    q_check_seq --> q_check_extra: number sequential
    q_check_extra --> q_error_extra: len(header.extra_data) > 32
    q_error_extra --> [*]: raise InvalidBlock
    q_check_extra --> q_check_diff: extra data valid
    q_check_diff --> q_error_diff: header.difficulty != 0
    q_error_diff --> [*]: raise InvalidBlock
    q_check_diff --> q_check_nonce: difficulty valid
    q_check_nonce --> q_error_nonce: header.nonce != 0x0000000000000000
    q_error_nonce --> [*]: raise InvalidBlock
    q_check_nonce --> q_check_ommers: nonce valid
    q_check_ommers --> q_error_ommers: header.ommers_hash != EMPTY_OMMER_HASH
    q_error_ommers --> [*]: raise InvalidBlock
    q_check_ommers --> q_check_parent: ommers hash valid
    q_check_parent --> q_error_parent: header.parent_hash != keccak256(rlp.encode(parent_header))
    q_error_parent --> [*]: raise InvalidBlock
    q_check_parent --> [*]: all checks pass
