stateDiagram-v2
    direction TB
    [*] --> q_target: parent_gas_target = parent_gas_limit // ELASTICITY_MULTIPLIER
    q_target --> q_check_limit: check_gas_limit(block_gas_limit, parent_gas_limit)
    q_check_limit --> q_error: false
    q_error --> [*]: raise InvalidBlock
    q_check_limit --> q_compare: true
    q_compare --> q_equal: parent_gas_used == parent_gas_target
    q_equal --> q_return: expected = parent_base_fee_per_gas
    q_compare --> q_above: parent_gas_used > parent_gas_target
    q_above --> q_calc_up: gas_used_delta = parent_gas_used - parent_gas_target
    q_calc_up --> q_delta_up: base_fee_per_gas_delta = max(delta // DENOMINATOR, 1)
    q_delta_up --> q_return: expected = parent_base_fee + delta
    q_compare --> q_below: parent_gas_used < parent_gas_target
    q_below --> q_calc_down: gas_used_delta = parent_gas_target - parent_gas_used
    q_calc_down --> q_delta_down: base_fee_per_gas_delta = delta // DENOMINATOR
    q_delta_down --> q_return: expected = parent_base_fee - delta
    q_return --> [*]: return Uint(expected_base_fee_per_gas)
