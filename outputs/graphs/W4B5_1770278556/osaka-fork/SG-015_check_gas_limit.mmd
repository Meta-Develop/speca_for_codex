stateDiagram-v2
    direction TB
    [*] --> q_calc: max_adjustment_delta = parent_gas_limit // GAS_LIMIT_ADJUSTMENT_FACTOR
    q_calc --> q_check_high: gas_limit >= parent + delta
    q_check_high --> q_false_high: true
    q_false_high --> [*]: return False
    q_check_high --> q_check_low: false
    q_check_low --> q_false_low: gas_limit <= parent - delta
    q_false_low --> [*]: return False
    q_check_low --> q_check_min: false
    q_check_min --> q_false_min: gas_limit < GAS_LIMIT_MINIMUM
    q_false_min --> [*]: return False
    q_check_min --> q_true: gas_limit >= minimum
    q_true --> [*]: return True
