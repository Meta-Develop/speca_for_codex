stateDiagram-v2
    direction TB
    [*] --> q_calc_avail: gas_available = block_gas_limit - block_gas_used
    q_calc_avail --> q_check_gas: blob_gas_available = MAX_BLOB_GAS - blob_gas_used
    q_check_gas --> q_error_gas: tx.gas > gas_available
    q_error_gas --> [*]: raise GasUsedExceedsLimitError
    q_check_gas --> q_calc_blob_gas: tx.gas <= gas_available
    q_calc_blob_gas --> q_check_blob_gas: tx_blob_gas_used = calculate_total_blob_gas(tx)
    q_check_blob_gas --> q_error_blob_gas: tx_blob_gas_used > blob_gas_available
    q_error_blob_gas --> [*]: raise BlobGasLimitExceededError
    q_check_blob_gas --> q_recover: blob gas within limit
    q_recover --> q_check_tx_type: sender_address = recover_sender(chain_id, tx)
    q_check_tx_type --> q_eip1559: tx is FeeMarket or Blob or SetCode
    q_check_tx_type --> q_legacy: tx is Legacy or AccessList
    q_eip1559 --> q_check_priority: check max_fee_per_gas fields
    q_check_priority --> q_error_priority: max_fee < max_priority_fee
    q_error_priority --> [*]: raise PriorityFeeGreaterThanMaxFeeError
    q_check_priority --> q_check_max_fee: priority fee valid
    q_check_max_fee --> q_error_max_fee: max_fee < base_fee
    q_error_max_fee --> [*]: raise InsufficientMaxFeePerGasError
    q_check_max_fee --> q_calc_eff_price: max fee valid
    q_calc_eff_price --> q_check_blob_tx: effective_gas_price = priority_fee + base_fee
    q_legacy --> q_check_legacy_price: check gas_price
    q_check_legacy_price --> q_error_legacy: gas_price < base_fee
    q_error_legacy --> [*]: raise InvalidBlock
    q_check_legacy_price --> q_check_blob_tx: effective_gas_price = tx.gas_price
    q_check_blob_tx --> q_is_blob: tx is BlobTransaction
    q_check_blob_tx --> q_check_setcode_to: tx is not BlobTransaction
    q_is_blob --> q_check_blob_count: check blob fields
    q_check_blob_count --> q_error_no_blob: blob_count == 0
    q_error_no_blob --> [*]: raise NoBlobDataError
    q_check_blob_count --> q_error_blob_limit: blob_count > BLOB_COUNT_LIMIT
    q_error_blob_limit --> [*]: raise BlobCountExceededError
    q_check_blob_count --> q_check_versions: 0 < blob_count <= limit
    q_check_versions --> q_error_version: any hash version != KZG
    q_error_version --> [*]: raise InvalidBlobVersionedHashError
    q_check_versions --> q_check_blob_price: all versions valid
    q_check_blob_price --> q_error_blob_price: max_fee_per_blob_gas < blob_gas_price
    q_error_blob_price --> [*]: raise InsufficientMaxFeePerBlobGasError
    q_check_blob_price --> q_check_setcode_to: blob price valid
    q_check_setcode_to --> q_check_to: tx is Blob or SetCode
    q_check_to --> q_error_to: tx.to is not Address
    q_error_to --> [*]: raise TransactionTypeContractCreationError
    q_check_to --> q_check_auth: tx.to is Address
    q_check_setcode_to --> q_check_nonce: other tx type
    q_check_auth --> q_check_auth_list: tx is SetCodeTransaction
    q_check_auth_list --> q_error_auth: not any(tx.authorizations)
    q_error_auth --> [*]: raise EmptyAuthorizationListError
    q_check_auth_list --> q_check_nonce: auth list valid
    q_check_auth --> q_check_nonce: tx is not SetCode
    q_check_nonce --> q_error_nonce_high: sender.nonce > tx.nonce
    q_error_nonce_high --> [*]: raise NonceMismatchError nonce too low
    q_check_nonce --> q_error_nonce_low: sender.nonce < tx.nonce
    q_error_nonce_low --> [*]: raise NonceMismatchError nonce too high
    q_check_nonce --> q_check_balance: nonce matches
    q_check_balance --> q_error_balance: balance < max_gas_fee + value
    q_error_balance --> [*]: raise InsufficientBalanceError
    q_check_balance --> q_check_code: balance sufficient
    q_check_code --> q_error_sender: has code and not valid delegation
    q_error_sender --> [*]: raise InvalidSenderError
    q_check_code --> q_return: sender is EOA or valid delegation
    q_return --> [*]: return (sender, effective_gas_price, blob_hashes, blob_gas)
