stateDiagram-v2
    direction TB
    [*] --> q_trie_set: trie_set(transactions_trie, rlp.encode(index), encode_transaction(tx))
    q_trie_set --> q_validate: intrinsic_gas, calldata_floor = validate_transaction(tx)
    q_validate --> q_check: sender, eff_price, blob_hashes, blob_gas = check_transaction(...)
    q_check --> q_calc_fees: sender_account = get_account(state, sender)
    q_calc_fees --> q_deduct: blob_gas_fee = calculate_data_fee(...) if Blob else 0
    q_deduct --> q_set_balance: effective_gas_fee = tx.gas * effective_gas_price
    q_set_balance --> q_nonce: gas = tx.gas - intrinsic_gas
    q_nonce --> q_prepare: increment_nonce(state, sender)
    q_prepare --> q_deduct_balance: sender_balance = balance - effective_gas_fee - blob_gas_fee
    q_deduct_balance --> q_build_access: set_account_balance(state, sender, new_balance)
    q_build_access --> q_build_tx_env: build access lists and authorizations
    q_build_tx_env --> q_prepare_msg: tx_env = TransactionEnvironment(...)
    q_prepare_msg --> q_execute: message = prepare_message(block_env, tx_env, tx)
    q_execute --> q_calc_refund: tx_output = process_message_call(message)
    q_calc_refund --> q_apply_floor: tx_gas_refund = min(gas_used // 5, refund_counter)
    q_apply_floor --> q_refund: tx_gas_used = max(gas_used - refund, calldata_floor_gas_cost)
    q_refund --> q_pay_miner: refund sender gas_left * effective_gas_price
    q_pay_miner --> q_destroy: coinbase += tx_gas_used * priority_fee_per_gas
    q_destroy --> q_update_output: destroy accounts_to_delete
    q_update_output --> q_receipt: block_gas_used += tx_gas_used, blob_gas_used += tx_blob_gas
    q_receipt --> q_trie_receipt: receipt = make_receipt(tx, error, block_gas_used, logs)
    q_trie_receipt --> q_logs: trie_set(receipts_trie, key, receipt)
    q_logs --> [*]: block_output.block_logs += tx_output.logs
