stateDiagram-v2
    direction TB
    [*] --> q_validate_sidecar: verify_data_column_sidecar(sidecar)
    q_validate_sidecar --> q_reject_invalid: not valid [REJECT]
    q_validate_sidecar --> q_check_subnet: valid
    q_reject_invalid --> [*]: reject
    q_check_subnet --> q_reject_subnet: compute_subnet_for_data_column_sidecar(sidecar.index) != subnet_id [REJECT]
    q_check_subnet --> q_check_future_slot: subnet matches
    q_reject_subnet --> [*]: reject
    q_check_future_slot --> q_ignore_future: block_header.slot > current_slot [IGNORE]
    q_check_future_slot --> q_check_finalized: block_header.slot <= current_slot
    q_ignore_future --> [*]: ignore
    q_check_finalized --> q_ignore_old: slot <= compute_start_slot_at_epoch(finalized_checkpoint.epoch) [IGNORE]
    q_check_finalized --> q_check_proposer_sig: slot > finalized start slot
    q_ignore_old --> [*]: ignore
    q_check_proposer_sig --> q_reject_sig: proposer signature invalid [REJECT]
    q_check_proposer_sig --> q_check_parent_seen: proposer signature valid
    q_reject_sig --> [*]: reject
    q_check_parent_seen --> q_ignore_no_parent: parent not seen [IGNORE]
    q_check_parent_seen --> q_check_parent_valid: parent seen
    q_ignore_no_parent --> [*]: ignore
    q_check_parent_valid --> q_reject_parent: parent fails validation [REJECT]
    q_check_parent_valid --> q_check_slot_higher: parent passes validation
    q_reject_parent --> [*]: reject
    q_check_slot_higher --> q_reject_slot: slot not higher than parent slot [REJECT]
    q_check_slot_higher --> q_check_finalized_ancestor: slot higher than parent
    q_reject_slot --> [*]: reject
    q_check_finalized_ancestor --> q_reject_ancestor: finalized checkpoint not ancestor [REJECT]
    q_check_finalized_ancestor --> q_check_inclusion_proof: finalized checkpoint is ancestor
    q_reject_ancestor --> [*]: reject
    q_check_inclusion_proof --> q_reject_inclusion: verify_data_column_sidecar_inclusion_proof fails [REJECT]
    q_check_inclusion_proof --> q_check_kzg_proofs: inclusion proof valid
    q_reject_inclusion --> [*]: reject
    q_check_kzg_proofs --> q_reject_kzg: verify_data_column_sidecar_kzg_proofs fails [REJECT]
    q_check_kzg_proofs --> q_check_first_sidecar: kzg proofs valid
    q_reject_kzg --> [*]: reject
    q_check_first_sidecar --> q_ignore_duplicate: not first sidecar for (slot, proposer_index, index) [IGNORE]
    q_check_first_sidecar --> q_check_expected_proposer: first valid sidecar
    q_ignore_duplicate --> [*]: ignore
    q_check_expected_proposer --> q_reject_proposer: proposer_index not expected for slot [REJECT]
    q_check_expected_proposer --> q_accept: proposer_index matches expected
    q_reject_proposer --> [*]: reject
    q_accept --> [*]: accept and forward
