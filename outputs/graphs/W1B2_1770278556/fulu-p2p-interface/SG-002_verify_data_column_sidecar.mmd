stateDiagram-v2
    direction TB
    [*] --> q_check_index: sidecar.index >= NUMBER_OF_COLUMNS
    q_check_index --> q_reject_index: sidecar.index >= NUMBER_OF_COLUMNS
    q_check_index --> q_check_empty: sidecar.index < NUMBER_OF_COLUMNS
    q_reject_index --> [*]: return False
    q_check_empty --> q_reject_empty: len(sidecar.kzg_commitments) == 0
    q_check_empty --> q_check_limit: len(sidecar.kzg_commitments) > 0
    q_reject_empty --> [*]: return False
    q_check_limit --> q_compute_epoch: epoch = compute_epoch_at_slot(sidecar.signed_block_header.message.slot)
    q_compute_epoch --> q_check_max_blobs: len(kzg_commitments) > get_blob_parameters(epoch).max_blobs_per_block
    q_check_max_blobs --> q_reject_limit: len(kzg_commitments) > max_blobs_per_block
    q_check_max_blobs --> q_check_lengths: len(kzg_commitments) <= max_blobs_per_block
    q_reject_limit --> [*]: return False
    q_check_lengths --> q_reject_lengths: len(column) != len(kzg_commitments) or len(column) != len(kzg_proofs)
    q_check_lengths --> q_accept: len(column) == len(kzg_commitments) == len(kzg_proofs)
    q_reject_lengths --> [*]: return False
    q_accept --> [*]: return True
