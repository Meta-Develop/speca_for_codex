              ["q_read_exp_len", "length_of_MODULUS = calldata[64..96]", "q_read_mod_len"],
              ["q_read_mod_len", "BASE = calldata[96..96+length_of_BASE]", "q_read_base"],
              ["q_read_base", "EXPONENT = calldata[96+length_of_BASE..96+length_of_BASE+length_of_EXPONENT]", "q_read_exp"],
              ["q_read_exp", "MODULUS = calldata[offset..offset+length_of_MODULUS]", "q_read_mod"],
              ["q_read_mod", "return (length_of_BASE, length_of_EXPONENT, length_of_MODULUS, BASE, EXPONENT, MODULUS)", "q_final"]
            ]
          },
          "invariants": [
            "INV-001: Each length field is read as a 256-bit big-endian unsigned integer from the first 96 bytes of calldata",
            "INV-002: BASE, EXPONENT, and MODULUS are read sequentially starting at byte offset 96"
          ]
        },
        {
