              "length_of_EXPONENT = calldata[32..64]",
              "length_of_MODULUS = calldata[64..96]",
              "BASE = calldata[96..96+length_of_BASE]",
              "EXPONENT = calldata[96+length_of_BASE..96+length_of_BASE+length_of_EXPONENT]",
              "MODULUS = calldata[offset..offset+length_of_MODULUS]",
              "return (length_of_BASE, length_of_EXPONENT, length_of_MODULUS, BASE, EXPONENT, MODULUS)"
            ],
            "E": [
              ["q_init", "length_of_BASE = calldata[0..32]", "q_read_base_len"],
