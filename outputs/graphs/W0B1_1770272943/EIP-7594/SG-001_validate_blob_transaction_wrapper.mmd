stateDiagram-v2
    direction TB
    [*] --> q_validate_counts: check len(blob_versioned_hashes) == len(blobs) == len(commitments)
    q_validate_counts --> q_check_blob_limit: counts_equal
    q_validate_counts --> q_reject: counts_not_equal
    q_check_blob_limit --> q_validate_proof_count: len(blobs) <= 6
    q_check_blob_limit --> q_reject: len(blobs) > 6
    q_validate_proof_count --> q_verify_hashes: len(cell_proofs) == CELLS_PER_EXT_BLOB * len(blobs)
    q_validate_proof_count --> q_reject: proof_count_mismatch
    q_verify_hashes --> q_iter_hash: i = 0
    q_iter_hash --> q_check_hash: i < len(commitments)
    q_iter_hash --> q_compute_cells: i >= len(commitments)
    q_check_hash --> q_iter_hash_next: kzg_to_versioned_hash(commitments[i]) == blob_versioned_hashes[i]
    q_check_hash --> q_reject: hash_mismatch
    q_iter_hash_next --> q_iter_hash: i = i + 1
    q_compute_cells --> q_verify_proofs: cells = compute_cells(blobs)
    q_verify_proofs --> q_accept: verify_cell_kzg_proof_batch(commitments, cells, cell_proofs) == true
    q_verify_proofs --> q_reject: verification_failed
    q_accept --> [*]: return valid
    q_reject --> [*]: return invalid
