stateDiagram-v2
    direction TB
    [*] --> q_init: validate_blob_transaction(tx)
    q_init --> q_check_blob_count: blob_count = len(tx.blobs)
    q_check_blob_count --> q_check_wrapper_version: blob_count <= 6
    q_check_blob_count --> q_reject: blob_count > 6
    q_check_wrapper_version --> q_validate_wrapper: tx.wrapper_version == 1
    q_check_wrapper_version --> q_reject: wrapper_version_invalid
    q_validate_wrapper --> q_accept: validate_blob_transaction_wrapper(tx) == valid
    q_validate_wrapper --> q_reject: wrapper_validation_failed
    q_accept --> [*]: return valid
    q_reject --> [*]: return invalid
