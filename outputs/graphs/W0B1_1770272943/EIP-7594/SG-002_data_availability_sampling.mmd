stateDiagram-v2
    direction TB
    [*] --> q_init: new_slot_received
    q_init --> q_determine_custody: custody_groups = get_custody_groups(node_id)
    q_determine_custody --> q_subscribe: subscribe_to_column_subnets(custody_groups)
    q_subscribe --> q_receive_columns: await gossip columns
    q_receive_columns --> q_check_coverage: columns_received = count_unique_columns()
    q_check_coverage --> q_sample_peers: columns_received < SAMPLES_PER_SLOT
    q_check_coverage --> q_local_check: columns_received >= SAMPLES_PER_SLOT
    q_sample_peers --> q_request: select_peers_for_missing_columns()
    q_request --> q_await_response: request_columns_from_peers()
    q_await_response --> q_check_coverage: columns_arrived
    q_await_response --> q_fail: timeout
    q_local_check --> q_verify_cells: verify_cell_kzg_proofs(sampled_cells)
    q_verify_cells --> q_available: all_proofs_valid
    q_verify_cells --> q_fail: proof_invalid
    q_available --> [*]: return data_available
    q_fail --> [*]: return data_unavailable
