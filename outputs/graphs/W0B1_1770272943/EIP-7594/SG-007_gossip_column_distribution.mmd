stateDiagram-v2
    direction TB
    [*] --> q_init: new_block_with_blobs(block)
    q_init --> q_extend_blobs: for each blob compute_cells(blob)
    q_extend_blobs --> q_build_columns: columns = build_column_matrix(extended_blobs)
    q_build_columns --> q_iter_col: col_idx = 0
    q_iter_col --> q_check_custody: col_idx < NUMBER_OF_COLUMNS
    q_iter_col --> q_done: col_idx >= NUMBER_OF_COLUMNS
    q_check_custody --> q_publish: col_idx in custody_groups
    q_check_custody --> q_skip: col_idx not in custody_groups
    q_publish --> q_gossip: gossip_column(col_idx, columns[col_idx])
    q_gossip --> q_next: column_published
    q_skip --> q_next: skip
    q_next --> q_iter_col: col_idx = col_idx + 1
    q_done --> [*]: return distribution_complete
