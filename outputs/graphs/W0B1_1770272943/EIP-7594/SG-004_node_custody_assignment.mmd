stateDiagram-v2
    direction TB
    [*] --> q_init: get_custody_groups(node_id)
    q_init --> q_check_validator: is_validator(node_id)
    q_check_validator --> q_set_count_validator: is_validator == true
    q_check_validator --> q_set_count_fullnode: is_validator == false
    q_set_count_validator --> q_compute: custody_count = CUSTODY_REQUIREMENT + validator_custody_bonus
    q_set_count_fullnode --> q_compute: custody_count = CUSTODY_REQUIREMENT
    q_compute --> q_derive: groups = derive_deterministic_groups(node_id, custody_count)
    q_derive --> q_map_subnets: column_subnets = map_groups_to_subnets(groups)
    q_map_subnets --> [*]: return column_subnets
