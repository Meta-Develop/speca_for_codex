stateDiagram-v2
    direction TB
    [*] --> q_init: start_reconstruction
    q_init --> q_count: acquired_columns = count_acquired_columns()
    q_count --> q_check_threshold: check reconstruction threshold
    q_check_threshold --> q_reconstruct: acquired_columns >= NUMBER_OF_COLUMNS / 2
    q_check_threshold --> q_request_more: acquired_columns < NUMBER_OF_COLUMNS / 2
    q_request_more --> q_find_peers: find_peers_with_missing_columns()
    q_find_peers --> q_fetch: request_columns(peers, missing_columns)
    q_fetch --> q_count: columns_received
    q_fetch --> q_fail: request_failed
    q_reconstruct --> q_iter_row: row_idx = 0
    q_iter_row --> q_decode_row: row_idx < num_blobs
    q_iter_row --> q_complete: row_idx >= num_blobs
    q_decode_row --> q_recover: recover_row(row_idx, available_cells)
    q_recover --> q_verify_row: verify_recovered_row(row_idx)
    q_verify_row --> q_next_row: row_valid
    q_verify_row --> q_fail: row_invalid
    q_next_row --> q_iter_row: row_idx = row_idx + 1
    q_complete --> [*]: return reconstructed_data
    q_fail --> [*]: return reconstruction_failed
