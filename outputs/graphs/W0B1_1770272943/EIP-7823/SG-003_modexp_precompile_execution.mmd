stateDiagram-v2
    direction TB
    [*] --> q_decode: decode calldata inputs
    q_decode --> q_check_base: length_of_BASE <= 1024
    q_check_base --> q_check_exp: true
    q_check_base --> q_oog: false
    q_check_exp --> q_check_mod: length_of_EXPONENT <= 1024
    q_check_exp --> q_oog: false
    q_check_mod --> q_gas_calc: length_of_MODULUS <= 1024
    q_check_mod --> q_oog: false
    q_gas_calc --> q_gas_check: gas_cost = compute_modexp_gas(lengths)
    q_gas_check --> q_compute: gas_available >= gas_cost
    q_gas_check --> q_oog_gas: gas_available < gas_cost
    q_compute --> q_output: result = pow(BASE, EXPONENT, MODULUS)
    q_output --> [*]: return result padded to length_of_MODULUS
    q_oog --> [*]: consume all gas and revert
    q_oog_gas --> [*]: out of gas error
