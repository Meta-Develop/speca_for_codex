---
title: blob_fee_regime_selection (EIP-7918)
---
stateDiagram-v2
    direction TB

    [*] --> q_init
    q_init --> q_read_header : read parent header fields
    q_read_header --> q_calc_target : target_blob_gas = GAS_PER_BLOB * blobSchedule.target
    q_calc_target --> q_check_total : total = excess_blob_gas + blob_gas_used
    q_check_total --> q_underflow : total < target_blob_gas
    q_check_total --> q_regime_check : total >= target_blob_gas
    q_underflow --> q_reset : excess_blob_gas = 0
    q_reset --> q_final : regime = RESET
    q_regime_check --> q_get_blob_fee : blob_base_fee = get_base_fee_per_blob_gas(parent)
    q_get_blob_fee --> q_compare_prices : BLOB_BASE_COST * base_fee vs GAS_PER_BLOB * blob_base_fee
    q_compare_prices --> q_exec_led : reserve_price > blob_price
    q_compare_prices --> q_blob_led : reserve_price <= blob_price
    q_exec_led --> q_increase_only : excess = excess + used * (max - target) / max
    q_increase_only --> q_final : regime = EXEC_FEE_LED
    q_blob_led --> q_normal_update : excess = excess + used - target_blob_gas
    q_normal_update --> q_final : regime = BLOB_FEE_LED
    q_final --> [*]

    note right of q_compare_prices
        INV-011: Exactly one of three regimes selected per block
        INV-012: In EXEC_FEE_LED, excess monotonically non-decreasing
        INV-013: In BLOB_FEE_LED, standard EIP-4844 update rule
        INV-014: Uses current block's blobSchedule, not parent's
        INV-015: Delayed response produces smooth blob base fee increase
    end note
