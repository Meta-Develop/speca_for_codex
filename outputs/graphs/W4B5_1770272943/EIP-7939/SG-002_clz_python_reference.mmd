stateDiagram-v2
    direction TB
    [*] --> q_validate_neg: x < 0
    q_validate_neg --> q_error_neg: true
    q_error_neg --> [*]: raise ValueError("clz is undefined for negative numbers")
    q_validate_neg --> q_validate_overflow: false
    q_validate_overflow --> q_error_overflow: x > 2**256 - 1
    q_error_overflow --> [*]: raise ValueError("clz is undefined for numbers larger than 2**256 - 1")
    q_validate_overflow --> q_check_zero: x <= 2**256 - 1
    q_check_zero --> q_return_256: x == 0
    q_return_256 --> [*]: return 256
    q_check_zero --> q_convert: x != 0
    q_convert --> q_compute: bin_str = bin(x).replace("0b", "")
    q_compute --> [*]: return 256 - len(bin_str)
