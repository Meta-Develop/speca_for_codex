stateDiagram-v2
    direction TB
    [*] --> q_step128: r = shl(7, lt(0xfff...f_128bit, x))
    q_step128 --> q_step64: r = or(r, shl(6, lt(0xfff...f_64bit, shr(r, x))))
    q_step64 --> q_step32: r = or(r, shl(5, lt(0xffffffff, shr(r, x))))
    q_step32 --> q_step16: r = or(r, shl(4, lt(0xffff, shr(r, x))))
    q_step16 --> q_step8: r = or(r, shl(3, lt(0xff, shr(r, x))))
    q_step8 --> q_lookup: t = byte(and(0x1f, shr(shr(r, x), LOOKUP_TABLE)), BYTE_TABLE)
    q_lookup --> q_adjust: r = add(xor(r, t), iszero(x))
    q_adjust --> [*]: return r
