        {
          "id": "SG-003",
          "name": "clz_solidity_binary_search",
          "mermaid_file": "EIP-7939/SG-003_clz_solidity_binary_search.mmd",
          "program_graph": {
            "Q": ["q_step128", "q_step64", "q_step32", "q_step16", "q_step8", "q_lookup", "q_adjust"],
            "q_init": "q_step128",
            "q_final": "q_adjust",
            "Act": [
              "r = shl(7, lt(0xfff...f_128bit, x))",
              "r = or(r, shl(6, lt(0xfff...f_64bit, shr(r, x))))",
              "r = or(r, shl(5, lt(0xffffffff, shr(r, x))))",
              "r = or(r, shl(4, lt(0xffff, shr(r, x))))",
              "r = or(r, shl(3, lt(0xff, shr(r, x))))",
              "t = byte(and(0x1f, shr(shr(r, x), LOOKUP_TABLE)), BYTE_TABLE)",
              "r = add(xor(r, t), iszero(x))",
              "return r"
            ],
            "E": [
              ["q_init", "r = shl(7, lt(0xfff...f_128bit, x))", "q_step128"],
              ["q_step128", "r = or(r, shl(6, lt(0xfff...f_64bit, shr(r, x))))", "q_step64"],
              ["q_step64", "r = or(r, shl(5, lt(0xffffffff, shr(r, x))))", "q_step32"],
              ["q_step32", "r = or(r, shl(4, lt(0xffff, shr(r, x))))", "q_step16"],
              ["q_step16", "r = or(r, shl(3, lt(0xff, shr(r, x))))", "q_step8"],
              ["q_step8", "t = byte(and(0x1f, shr(shr(r, x), LOOKUP_TABLE)), BYTE_TABLE)", "q_lookup"],
              ["q_lookup", "r = add(xor(r, t), iszero(x))", "q_adjust"],
              ["q_adjust", "return r", "q_final"]
            ]
          },
          "invariants": [
            "INV-001: After each step, r accumulates the bit position of the most significant set bit in progressively narrowing halves",
            "INV-002: The binary search narrows from 128-bit to 8-bit granularity",
            "INV-003: The lookup table provides exact CLZ for the final 5-bit window",
            "INV-004: iszero(x) adjustment ensures CLZ(0) = 256"
          ]
        },
        {
          "id": "SG-004",
          "name": "clz_32bit",
          "mermaid_file": "EIP-7939/SG-004_clz_32bit.mmd",
          "program_graph": {
            "Q": ["q_init", "q_check16", "q_shift16", "q_check8", "q_shift8", "q_check4", "q_shift4", "q_check2", "q_shift2", "q_check1", "q_inc", "q_return"],
            "q_init": "q_init",
            "q_final": "q_return",
            "Act": [
