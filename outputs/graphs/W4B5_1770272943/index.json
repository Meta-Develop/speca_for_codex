              ["q_check0", "x[0] != 0", "q_ret0"],
              ["q_ret0", "return 224 + clz(x[0])", "q_final"],
              ["q_check0", "x[0] == 0", "q_ret_256"],
              ["q_ret_256", "return 256", "q_final"]
            ]
