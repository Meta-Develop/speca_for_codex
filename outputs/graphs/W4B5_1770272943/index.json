              ["q_check_zero", "x == 0", "q_return_256"],
              ["q_return_256", "return 256", "q_final"],
              ["q_check_zero", "x != 0", "q_convert"],
              ["q_convert", "bin_str = bin(x).replace(\"0b\", \"\")", "q_compute"],
