              "r += 8, x <<= 8",
              "!(x & 0xF0000000)",
              "x & 0xF0000000",
              "r += 4, x <<= 4",
              "!(x & 0xC0000000)",
              "x & 0xC0000000",
              "r += 2, x <<= 2",
              "!(x & 0x80000000)",
              "x & 0x80000000",
              "r += 1",
              "return r"
