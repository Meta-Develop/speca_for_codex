            "E": [
              ["q_init", "r = 0", "q_check16"],
              ["q_check16", "!(x & 0xFFFF0000)", "q_shift16"],
              ["q_check16", "x & 0xFFFF0000", "q_check8"],
              ["q_shift16", "r += 16, x <<= 16", "q_check8"],
              ["q_check8", "!(x & 0xFF000000)", "q_shift8"],
              ["q_check8", "x & 0xFF000000", "q_check4"],
              ["q_shift8", "r += 8, x <<= 8", "q_check4"],
              ["q_check4", "!(x & 0xF0000000)", "q_shift4"],
              ["q_check4", "x & 0xF0000000", "q_check2"],
              ["q_shift4", "r += 4, x <<= 4", "q_check2"],
              ["q_check2", "!(x & 0xC0000000)", "q_shift2"],
              ["q_check2", "x & 0xC0000000", "q_check1"],
              ["q_shift2", "r += 2, x <<= 2", "q_check1"],
              ["q_check1", "!(x & 0x80000000)", "q_inc"],
              ["q_check1", "x & 0x80000000", "q_return"],
              ["q_inc", "r += 1", "q_return"],
              ["q_return", "return r", "q_final"]
            ]
          },
          "invariants": [
            "INV-001: At each step, the upper bits of x are guaranteed to be zero if the corresponding mask test failed",
            "INV-002: r always equals the count of leading zeros in the original x that have been accounted for so far",
            "INV-003: The binary search halves the remaining bit window at each step (16, 8, 4, 2, 1)"
