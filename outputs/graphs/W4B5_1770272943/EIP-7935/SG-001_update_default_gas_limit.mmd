stateDiagram-v2
    direction TB
    [*] --> q_read_current: current_limit = read_default_config()
    q_read_current --> q_check: current_limit != 60000000
    q_read_current --> q_final_noop: current_limit == 60000000
    q_check --> q_update: set_default_gas_limit(60000000)
    q_update --> q_validate: new_limit = read_default_config()
    q_validate --> q_confirm: new_limit == 60000000
    q_validate --> q_error: new_limit != 60000000
    q_confirm --> [*]: return success
    q_error --> [*]: return error
    q_final_noop --> [*]: return already_set
