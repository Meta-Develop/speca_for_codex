stateDiagram-v2
    direction TB
    [*] --> q_calc_worst: worst_case_size = compute_worst_case_block_size(gas_limit)
    q_calc_worst --> q_check_gossip: worst_case_size <= CL_GOSSIP_LIMIT
    q_calc_worst --> q_reject: worst_case_size > CL_GOSSIP_LIMIT
    q_check_gossip --> q_check_threshold: gas_limit < 150000000
    q_check_gossip --> q_reject: gas_limit >= 150000000
    q_check_threshold --> q_check_tx_limit: max_tx_gas <= TX_GAS_LIMIT
    q_check_threshold --> q_warn: max_tx_gas > TX_GAS_LIMIT
    q_check_tx_limit --> [*]: return safe
    q_warn --> q_coordinate: coordinate_with_tx_limit_eip()
    q_coordinate --> [*]: return conditional_safe
    q_reject --> [*]: return unsafe
