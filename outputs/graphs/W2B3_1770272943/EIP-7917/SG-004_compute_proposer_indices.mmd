stateDiagram-v2
    direction TB
    [*] --> q_start_slot: start_slot = compute_start_slot_at_epoch(epoch)
    q_start_slot --> q_gen_seeds: seeds = [hash(seed + uint_to_bytes(start_slot + i)) for i in range(SLOTS_PER_EPOCH)]
    q_gen_seeds --> q_iter: i = 0
    q_iter --> q_compute: i < SLOTS_PER_EPOCH
    q_compute --> q_iter: result[i] = compute_proposer_index(state, indices, seeds[i]); i = i + 1
    q_iter --> [*]: i >= SLOTS_PER_EPOCH; return result
