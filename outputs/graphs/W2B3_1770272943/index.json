              ["q_check_slot", "EL slot == start_of_epoch(CL epoch)", "q_check_max"],
              ["q_fail_slot", "revert inconsistent slot/epoch alignment", "q_final"],
              ["q_check_max", "EL max != CL MAX_BLOBS_PER_BLOCK", "q_fail_max"],
              ["q_check_max", "EL max == CL MAX_BLOBS_PER_BLOCK", "q_pass"],
              ["q_fail_max", "revert inconsistent max blob count", "q_final"],
              ["q_pass", "validate next fork", "q_iter"],
              ["q_iter", "all forks validated successfully", "q_final"]
