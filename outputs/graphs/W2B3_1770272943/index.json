          "program_graph": {
            "Q": ["q_init", "q_load_el", "q_load_cl", "q_iter", "q_check_slot", "q_fail_slot", "q_check_max", "q_fail_max", "q_pass", "q_final"],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
              "load EL blobSchedule entries",
              "load CL BLOB_SCHEDULE entries",
              "for each BPO fork",
              "validate EL slot aligns with CL epoch start",
              "EL slot != start_of_epoch(CL epoch)",
              "EL slot == start_of_epoch(CL epoch)",
              "revert inconsistent slot/epoch alignment",
              "EL max != CL MAX_BLOBS_PER_BLOCK",
              "EL max == CL MAX_BLOBS_PER_BLOCK",
              "revert inconsistent max blob count",
              "validate next fork",
              "all forks validated successfully"
