        {
          "id": "SG-003",
          "name": "compute_fork_digest",
          "mermaid_file": "EIP-7892/SG-003_compute_fork_digest.mmd",
          "program_graph": {
            "Q": ["q_init", "q_base", "q_sort", "q_init_iter", "q_iter", "q_found", "q_no_params", "q_check_none", "q_return_base", "q_assert", "q_mask", "q_xor", "q_final"],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
