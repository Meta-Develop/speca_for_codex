stateDiagram-v2
    direction TB
    [*] --> q_base: base_digest = compute_fork_data_root(current_version, genesis_validators_root) first 4 bytes
    q_base --> q_sort: sorted_schedule = sorted(blob_schedule, key=epoch, reverse=True)
    q_sort --> q_init_iter: blob_params = None
    q_init_iter --> q_iter: for entry in sorted_schedule
    q_iter --> q_found: current_epoch >= entry.epoch
    q_iter --> q_iter: current_epoch < entry.epoch
    q_iter --> q_no_params: no more entries
    q_found --> q_check_none: blob_params = entry
    q_no_params --> q_check_none: blob_params is still None
    q_check_none --> q_return_base: blob_params is None
    q_check_none --> q_assert: blob_params is not None
    q_return_base --> [*]: return ForkDigest(base_digest)
    q_assert --> q_mask: assert 0 <= blob_params.max_blobs_per_block <= 0xFFFFFFFF
    q_mask --> q_xor: mask = blob_params.max_blobs_per_block.to_bytes(4, big)
    q_xor --> [*]: return ForkDigest(base_digest XOR mask)
