stateDiagram-v2
    direction TB
    [*] --> q_compute: target_blob_gas = GAS_PER_BLOB * blob_schedule.target
    q_compute --> q_check: evaluate parent.excess_blob_gas + parent.blob_gas_used
    q_check --> q_underflow: parent.excess_blob_gas + parent.blob_gas_used < target_blob_gas
    q_check --> q_excess: parent.excess_blob_gas + parent.blob_gas_used >= target_blob_gas
    q_underflow --> [*]: return 0
    q_excess --> [*]: return parent.excess_blob_gas + parent.blob_gas_used - target_blob_gas
