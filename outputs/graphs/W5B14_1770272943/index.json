        {
          "id": "SG-008",
          "name": "bytes_to_nibble_list",
          "mermaid_file": "osaka-trie/SG-008_bytes_to_nibble_list.mmd",
          "program_graph": {
            "Q": ["q_init", "q_iter", "q_body", "q_high", "q_low", "q_return", "q_final"],
            "q_init": "q_init",
