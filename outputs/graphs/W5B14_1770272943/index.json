              ["q_low", "byte_index = byte_index + 1", "q_iter"],
              ["q_iter", "byte_index >= len(bytes_)", "q_return"],
              ["q_return", "return Bytes(nibble_list)", "q_final"]
            ]
          },
          "invariants": [
            "INV-014: Output length is exactly 2 * len(input)",
            "INV-015: Each output nibble is in range [0, 15]",
