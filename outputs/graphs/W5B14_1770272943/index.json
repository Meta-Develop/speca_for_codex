        {
          "id": "SG-007",
          "name": "nibble_list_to_compact",
          "mermaid_file": "osaka-trie/SG-007_nibble_list_to_compact.mmd",
          "program_graph": {
            "Q": ["q_init", "q_check_parity", "q_even_append", "q_even_iter", "q_even_body", "q_odd", "q_odd_append", "q_odd_iter", "q_odd_body", "q_return", "q_final"],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
              "compact = bytearray()",
              "len(x) % 2 == 0",
              "len(x) % 2 != 0",
              "compact.append(16 * (2 * is_leaf))",
              "for i in range(0, len(x), 2)",
              "i < len(x)",
              "compact.append(16 * x[i] + x[i+1])",
              "i >= len(x)",
              "compact.append(16 * ((2*is_leaf)+1) + x[0])",
              "for i in range(1, len(x), 2)",
              "return Bytes(compact)"
            ],
            "E": [
              ["q_init", "compact = bytearray()", "q_check_parity"],
              ["q_check_parity", "len(x) % 2 == 0", "q_even_append"],
              ["q_check_parity", "len(x) % 2 != 0", "q_odd"],
              ["q_even_append", "compact.append(16 * (2 * is_leaf))", "q_even_iter"],
              ["q_even_iter", "i < len(x)", "q_even_body"],
              ["q_even_body", "compact.append(16 * x[i] + x[i+1])", "q_even_iter"],
              ["q_even_iter", "i >= len(x)", "q_return"],
              ["q_odd", "compact.append(16 * ((2*is_leaf)+1) + x[0])", "q_odd_append"],
              ["q_odd_append", "for i in range(1, len(x), 2)", "q_odd_iter"],
              ["q_odd_iter", "i < len(x)", "q_odd_body"],
              ["q_odd_body", "compact.append(16 * x[i] + x[i+1])", "q_odd_iter"],
              ["q_odd_iter", "i >= len(x)", "q_return"],
              ["q_return", "return Bytes(compact)", "q_final"]
            ]
          },
          "invariants": [
