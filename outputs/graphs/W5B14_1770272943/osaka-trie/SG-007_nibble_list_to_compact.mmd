stateDiagram-v2
    direction TB
    [*] --> q_init: compact = bytearray()
    q_init --> q_check_parity: len(x) % 2 == 0
    q_init --> q_odd: len(x) % 2 != 0
    q_check_parity --> q_even_append: compact.append(16 * (2 * is_leaf))
    q_even_append --> q_even_iter: for i in range(0, len(x), 2)
    q_even_iter --> q_even_body: i < len(x)
    q_even_body --> q_even_iter: compact.append(16 * x[i] + x[i+1])
    q_even_iter --> q_return: i >= len(x)
    q_odd --> q_odd_append: compact.append(16 * ((2*is_leaf)+1) + x[0])
    q_odd_append --> q_odd_iter: for i in range(1, len(x), 2)
    q_odd_iter --> q_odd_body: i < len(x)
    q_odd_body --> q_odd_iter: compact.append(16 * x[i] + x[i+1])
    q_odd_iter --> q_return: i >= len(x)
    q_return --> [*]: return Bytes(compact)
