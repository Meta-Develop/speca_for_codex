stateDiagram-v2
    direction TB
    [*] --> q_check_none: node is None
    [*] --> q_check_leaf: node is LeafNode
    [*] --> q_check_ext: node is ExtensionNode
    [*] --> q_check_branch: node is BranchNode
    [*] --> q_error: invalid type
    q_check_none --> q_encode: unencoded = b""
    q_check_leaf --> q_encode: unencoded = (nibble_list_to_compact(rest_of_key, True), value)
    q_check_ext --> q_encode: unencoded = (nibble_list_to_compact(key_segment, False), subnode)
    q_check_branch --> q_encode: unencoded = list(subnodes) + [value]
    q_error --> [*]: raise AssertionError
    q_encode --> q_check_len: encoded = rlp.encode(unencoded)
    q_check_len --> q_return_unencoded: len(encoded) < 32
    q_check_len --> q_return_hash: len(encoded) >= 32
    q_return_unencoded --> [*]: return unencoded
    q_return_hash --> [*]: return keccak256(encoded)
