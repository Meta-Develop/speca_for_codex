stateDiagram-v2
    direction TB
    [*] --> q_init: mapped = {}
    q_init --> q_iter: for preimage, value in trie._data.items()
    q_iter --> q_check_account: isinstance(value, Account)
    q_iter --> q_encode_other: not isinstance(value, Account)
    q_check_account --> q_assert_root: get_storage_root is not None
    q_assert_root --> q_encode_account: encoded_value = encode_node(value, get_storage_root(Address(preimage)))
    q_encode_other --> q_encode_plain: encoded_value = encode_node(value)
    q_encode_account --> q_check_empty: encoded_value == b""
    q_encode_plain --> q_check_empty: encoded_value == b""
    q_check_empty --> q_error: True
    q_check_empty --> q_check_secured: False
    q_error --> [*]: raise AssertionError
    q_check_secured --> q_hash_key: trie.secured == True
    q_check_secured --> q_raw_key: trie.secured == False
    q_hash_key --> q_map: key = keccak256(preimage)
    q_raw_key --> q_map: key = preimage
    q_map --> q_iter: mapped[bytes_to_nibble_list(key)] = encoded_value
    q_iter --> q_return: iteration complete
    q_return --> [*]: return mapped
