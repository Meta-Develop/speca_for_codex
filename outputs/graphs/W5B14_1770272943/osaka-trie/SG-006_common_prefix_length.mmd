stateDiagram-v2
    direction TB
    [*] --> q_iter: i = 0
    q_iter --> q_check_bounds: i < len(a)
    q_check_bounds --> q_check_mismatch: i < len(b)
    q_check_bounds --> q_return_i: i >= len(b)
    q_check_mismatch --> q_next: a[i] == b[i]
    q_check_mismatch --> q_return_i: a[i] != b[i]
    q_next --> q_iter: i = i + 1
    q_return_i --> [*]: return i
    q_iter --> q_return_len: i >= len(a)
    q_return_len --> [*]: return len(a)
