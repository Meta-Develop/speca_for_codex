stateDiagram-v2
    direction TB
    [*] --> q_init: nibble_list = bytearray(2 * len(bytes_))
    q_init --> q_iter: for byte_index, byte in enumerate(bytes_)
    q_iter --> q_body: byte_index < len(bytes_)
    q_body --> q_high: nibble_list[byte_index*2] = (byte and 0xF0) >> 4
    q_high --> q_low: nibble_list[byte_index*2+1] = byte and 0x0F
    q_low --> q_iter: byte_index = byte_index + 1
    q_iter --> q_return: byte_index >= len(bytes_)
    q_return --> [*]: return Bytes(nibble_list)
