stateDiagram-v2
    direction TB
    [*] --> q_check_empty: len(obj) == 0
    q_check_empty --> q_return_none: True
    q_return_none --> [*]: return None
    q_check_empty --> q_get_key: False
    q_get_key --> q_check_leaf: arbitrary_key = next(iter(obj))
    q_check_leaf --> q_return_leaf: len(obj) == 1
    q_return_leaf --> [*]: return LeafNode(arbitrary_key[level:], obj[arbitrary_key])
    q_check_leaf --> q_find_prefix: len(obj) > 1
    q_find_prefix --> q_prefix_iter: substring = arbitrary_key[level:], prefix_length = len(substring)
    q_prefix_iter --> q_prefix_body: for key in obj
    q_prefix_body --> q_update_prefix: prefix_length = min(prefix_length, common_prefix_length(substring, key[level:]))
    q_update_prefix --> q_prefix_break: prefix_length == 0
    q_update_prefix --> q_prefix_iter: prefix_length > 0
    q_prefix_break --> q_check_extension: done iterating
    q_prefix_iter --> q_check_extension: iteration complete
    q_check_extension --> q_return_ext: prefix_length > 0
    q_return_ext --> [*]: return ExtensionNode(prefix, encode_internal_node(patricialize(obj, level+prefix_length)))
    q_check_extension --> q_build_branch: prefix_length == 0
    q_build_branch --> q_branch_iter: branches = [{} for _ in range(16)], value = b""
    q_branch_iter --> q_branch_body: for key in obj
    q_branch_body --> q_set_value: len(key) == level
    q_branch_body --> q_add_branch: len(key) != level
    q_set_value --> q_validate_type: isinstance(obj[key], (Account, Receipt, Uint))
    q_validate_type --> q_branch_error: True
    q_branch_error --> [*]: raise AssertionError
    q_validate_type --> q_assign_value: False
    q_assign_value --> q_branch_iter: value = obj[key]
    q_add_branch --> q_branch_iter: branches[key[level]][key] = obj[key]
    q_branch_iter --> q_build_subnodes: iteration complete
    q_build_subnodes --> q_return_branch: subnodes = tuple(encode_internal_node(patricialize(branches[k], level+1)) for k in range(16))
    q_return_branch --> [*]: return BranchNode(subnodes, value)
