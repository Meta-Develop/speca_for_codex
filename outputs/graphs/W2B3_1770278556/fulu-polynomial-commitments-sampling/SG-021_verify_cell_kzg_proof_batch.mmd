    q_convert_evals --> q_convert_proofs : proofs = [bytes_to_kzg_proof(p) for p in proofs_bytes]
    q_convert_proofs --> q_verify : result = verify_cell_kzg_proof_batch_impl(...)
    q_verify --> [*] : return result

