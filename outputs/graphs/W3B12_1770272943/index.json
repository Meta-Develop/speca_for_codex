        {
          "id": "SG-001",
          "name": "extract_deposit_data",
          "mermaid_file": "osaka-requests/SG-001_extract_deposit_data.mmd",
          "program_graph": {
            "Q": [
              "q_validate_len", "q_error_len", "q_read_offsets",
              "q_check_pubkey_off", "q_error_pk_off",
              "q_check_wc_off", "q_error_wc_off",
              "q_check_amt_off", "q_error_amt_off",
              "q_check_sig_off", "q_error_sig_off",
              "q_check_idx_off", "q_error_idx_off",
              "q_check_pk_size", "q_error_pk_size", "q_extract_pk",
              "q_check_wc_size", "q_error_wc_size", "q_extract_wc",
              "q_check_amt_size", "q_error_amt_size", "q_extract_amt",
              "q_check_sig_size", "q_error_sig_size", "q_extract_sig",
              "q_check_idx_size", "q_error_idx_size", "q_extract_idx",
              "q_concat", "q_final"
            ],
            "q_init": "q_validate_len",
            "q_final": "q_final",
            "Act": [
              "len(data) != DEPOSIT_EVENT_LENGTH",
              "raise InvalidBlock(\"Invalid deposit event data length\")",
              "pubkey_offset = Uint.from_be_bytes(data[0..32])",
              "pubkey_offset != PUBKEY_OFFSET",
              "raise InvalidBlock(\"Invalid pubkey offset in deposit log\")",
              "pubkey_offset == PUBKEY_OFFSET",
              "withdrawal_credentials_offset != WITHDRAWAL_CREDENTIALS_OFFSET",
              "raise InvalidBlock(\"Invalid withdrawal credentials offset\")",
              "withdrawal_credentials_offset == WITHDRAWAL_CREDENTIALS_OFFSET",
              "amount_offset != AMOUNT_OFFSET",
              "raise InvalidBlock(\"Invalid amount offset\")",
              "amount_offset == AMOUNT_OFFSET",
              "signature_offset != SIGNATURE_OFFSET",
              "raise InvalidBlock(\"Invalid signature offset\")",
              "signature_offset == SIGNATURE_OFFSET",
              "index_offset != INDEX_OFFSET",
              "raise InvalidBlock(\"Invalid index offset\")",
              "index_offset == INDEX_OFFSET",
              "pubkey_size != PUBKEY_SIZE",
              "raise InvalidBlock(\"Invalid pubkey size\")",
              "pubkey_size == PUBKEY_SIZE",
              "pubkey = data[pubkey_offset+32 .. +PUBKEY_SIZE]",
              "withdrawal_credentials_size != WITHDRAWAL_CREDENTIALS_SIZE",
              "raise InvalidBlock(\"Invalid withdrawal credentials size\")",
              "withdrawal_credentials_size == WITHDRAWAL_CREDENTIALS_SIZE",
              "withdrawal_credentials = data[wc_offset+32 .. +WC_SIZE]",
              "amount_size != AMOUNT_SIZE",
              "raise InvalidBlock(\"Invalid amount size\")",
              "amount_size == AMOUNT_SIZE",
              "amount = data[amount_offset+32 .. +AMOUNT_SIZE]",
              "signature_size != SIGNATURE_SIZE",
              "raise InvalidBlock(\"Invalid signature size\")",
              "signature_size == SIGNATURE_SIZE",
              "signature = data[sig_offset+32 .. +SIGNATURE_SIZE]",
              "index_size != INDEX_SIZE",
              "raise InvalidBlock(\"Invalid index size\")",
              "index_size == INDEX_SIZE",
              "index = data[index_offset+32 .. +INDEX_SIZE]",
              "return pubkey + wc + amount + signature + index"
            ],
            "E": [
              ["q_validate_len", "len(data) != DEPOSIT_EVENT_LENGTH is True", "q_error_len"],
              ["q_error_len", "raise InvalidBlock(\"Invalid deposit event data length\")", "q_final"],
              ["q_validate_len", "len(data) != DEPOSIT_EVENT_LENGTH is False", "q_read_offsets"],
              ["q_read_offsets", "pubkey_offset = Uint.from_be_bytes(data[0..32])", "q_check_pubkey_off"],
              ["q_check_pubkey_off", "pubkey_offset != PUBKEY_OFFSET", "q_error_pk_off"],
              ["q_error_pk_off", "raise InvalidBlock(\"Invalid pubkey offset in deposit log\")", "q_final"],
              ["q_check_pubkey_off", "pubkey_offset == PUBKEY_OFFSET", "q_check_wc_off"],
              ["q_check_wc_off", "withdrawal_credentials_offset != WITHDRAWAL_CREDENTIALS_OFFSET", "q_error_wc_off"],
              ["q_error_wc_off", "raise InvalidBlock(\"Invalid withdrawal credentials offset\")", "q_final"],
              ["q_check_wc_off", "withdrawal_credentials_offset == WITHDRAWAL_CREDENTIALS_OFFSET", "q_check_amt_off"],
              ["q_check_amt_off", "amount_offset != AMOUNT_OFFSET", "q_error_amt_off"],
              ["q_error_amt_off", "raise InvalidBlock(\"Invalid amount offset\")", "q_final"],
              ["q_check_amt_off", "amount_offset == AMOUNT_OFFSET", "q_check_sig_off"],
              ["q_check_sig_off", "signature_offset != SIGNATURE_OFFSET", "q_error_sig_off"],
              ["q_error_sig_off", "raise InvalidBlock(\"Invalid signature offset\")", "q_final"],
              ["q_check_sig_off", "signature_offset == SIGNATURE_OFFSET", "q_check_idx_off"],
              ["q_check_idx_off", "index_offset != INDEX_OFFSET", "q_error_idx_off"],
              ["q_error_idx_off", "raise InvalidBlock(\"Invalid index offset\")", "q_final"],
              ["q_check_idx_off", "index_offset == INDEX_OFFSET", "q_check_pk_size"],
              ["q_check_pk_size", "pubkey_size != PUBKEY_SIZE", "q_error_pk_size"],
              ["q_error_pk_size", "raise InvalidBlock(\"Invalid pubkey size\")", "q_final"],
              ["q_check_pk_size", "pubkey_size == PUBKEY_SIZE", "q_extract_pk"],
              ["q_extract_pk", "pubkey = data[pubkey_offset+32 .. +PUBKEY_SIZE]", "q_check_wc_size"],
              ["q_check_wc_size", "withdrawal_credentials_size != WITHDRAWAL_CREDENTIALS_SIZE", "q_error_wc_size"],
              ["q_error_wc_size", "raise InvalidBlock(\"Invalid withdrawal credentials size\")", "q_final"],
              ["q_check_wc_size", "withdrawal_credentials_size == WITHDRAWAL_CREDENTIALS_SIZE", "q_extract_wc"],
              ["q_extract_wc", "withdrawal_credentials = data[wc_offset+32 .. +WC_SIZE]", "q_check_amt_size"],
              ["q_check_amt_size", "amount_size != AMOUNT_SIZE", "q_error_amt_size"],
              ["q_error_amt_size", "raise InvalidBlock(\"Invalid amount size\")", "q_final"],
              ["q_check_amt_size", "amount_size == AMOUNT_SIZE", "q_extract_amt"],
              ["q_extract_amt", "amount = data[amount_offset+32 .. +AMOUNT_SIZE]", "q_check_sig_size"],
              ["q_check_sig_size", "signature_size != SIGNATURE_SIZE", "q_error_sig_size"],
              ["q_error_sig_size", "raise InvalidBlock(\"Invalid signature size\")", "q_final"],
              ["q_check_sig_size", "signature_size == SIGNATURE_SIZE", "q_extract_sig"],
              ["q_extract_sig", "signature = data[sig_offset+32 .. +SIGNATURE_SIZE]", "q_check_idx_size"],
              ["q_check_idx_size", "index_size != INDEX_SIZE", "q_error_idx_size"],
              ["q_error_idx_size", "raise InvalidBlock(\"Invalid index size\")", "q_final"],
              ["q_check_idx_size", "index_size == INDEX_SIZE", "q_extract_idx"],
              ["q_extract_idx", "index = data[index_offset+32 .. +INDEX_SIZE]", "q_concat"],
              ["q_concat", "return pubkey + wc + amount + signature + index", "q_final"]
            ]
          },
          "invariants": [
            "INV-001: data length must equal DEPOSIT_EVENT_LENGTH (576 bytes)",
            "INV-002: All five offsets (pubkey, withdrawal_credentials, amount, signature, index) must match their expected constants",
            "INV-003: All five sizes (pubkey=48, wc=32, amount=8, signature=96, index=8) must match their expected constants",
            "INV-004: The returned bytes are exactly pubkey(48) + withdrawal_credentials(32) + amount(8) + signature(96) + index(8) = 192 bytes",
            "INV-005: Every validation failure terminates with InvalidBlock exception"
          ]
        },
        {
          "id": "SG-002",
          "name": "parse_deposit_requests",
          "mermaid_file": "osaka-requests/SG-002_parse_deposit_requests.mmd",
          "program_graph": {
            "Q": [
              "q_init", "q_iter_keys", "q_get_receipt", "q_decode",
              "q_iter_logs", "q_check_addr", "q_check_topic",
              "q_extract", "q_append", "q_final"
            ],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
              "deposit_requests = b\"\"",
              "for key in block_output.receipt_keys",
              "has next key",
              "receipt = trie_get(block_output.receipts_trie, key)",
              "decoded_receipt = decode_receipt(receipt)",
              "for log in decoded_receipt.logs",
              "log.address == DEPOSIT_CONTRACT_ADDRESS",
              "log.address != DEPOSIT_CONTRACT_ADDRESS",
              "len(log.topics) > 0 AND log.topics[0] == DEPOSIT_EVENT_SIGNATURE_HASH",
              "topic check fails",
              "request = extract_deposit_data(log.data)",
              "deposit_requests += request",
              "no more logs",
              "no more keys, return deposit_requests"
            ],
            "E": [
              ["q_init", "deposit_requests = b\"\"", "q_iter_keys"],
              ["q_iter_keys", "has next key", "q_get_receipt"],
              ["q_get_receipt", "receipt = trie_get(block_output.receipts_trie, key)", "q_decode"],
              ["q_decode", "decoded_receipt = decode_receipt(receipt)", "q_iter_logs"],
              ["q_iter_logs", "for log in decoded_receipt.logs", "q_check_addr"],
              ["q_check_addr", "log.address == DEPOSIT_CONTRACT_ADDRESS", "q_check_topic"],
              ["q_check_addr", "log.address != DEPOSIT_CONTRACT_ADDRESS", "q_iter_logs"],
              ["q_check_topic", "len(log.topics) > 0 AND log.topics[0] == DEPOSIT_EVENT_SIGNATURE_HASH", "q_extract"],
              ["q_check_topic", "topic check fails", "q_iter_logs"],
              ["q_extract", "request = extract_deposit_data(log.data)", "q_append"],
              ["q_append", "deposit_requests += request", "q_iter_logs"],
              ["q_iter_logs", "no more logs", "q_iter_keys"],
              ["q_iter_keys", "no more keys, return deposit_requests", "q_final"]
            ]
          },
          "invariants": [
            "INV-006: Only logs from DEPOSIT_CONTRACT_ADDRESS are considered",
            "INV-007: Only logs with topics[0] == DEPOSIT_EVENT_SIGNATURE_HASH are processed",
            "INV-008: Receipts are processed in receipt_keys order (preserving deposit ordering)",
            "INV-009: deposit_requests accumulates valid deposit data without gaps",
            "INV-010: trie_get must return a non-None receipt for every key in receipt_keys"
          ]
        },
        {
          "id": "SG-003",
          "name": "compute_requests_hash",
          "mermaid_file": "osaka-requests/SG-003_compute_requests_hash.mmd",
          "program_graph": {
            "Q": ["q_init", "q_iter", "q_hash", "q_update", "q_return", "q_final"],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
              "m = sha256()",
              "for request in requests",
              "has next request",
              "digest = sha256(request).digest()",
              "m.update(digest)",
              "no more requests",
              "return m.digest()"
            ],
            "E": [
              ["q_init", "m = sha256()", "q_iter"],
              ["q_iter", "has next request", "q_hash"],
              ["q_hash", "digest = sha256(request).digest()", "q_update"],
              ["q_update", "m.update(digest)", "q_iter"],
              ["q_iter", "no more requests", "q_return"],
              ["q_return", "return m.digest()", "q_final"]
            ]
          },
          "invariants": [
            "INV-011: Each request is individually SHA-256 hashed before being fed into the outer hash",
            "INV-012: The hash is computed over requests in list order (order-dependent)",
            "INV-013: An empty requests list produces sha256() of empty input (the SHA-256 of nothing updated)"
          ]
        }
      ]
    }
