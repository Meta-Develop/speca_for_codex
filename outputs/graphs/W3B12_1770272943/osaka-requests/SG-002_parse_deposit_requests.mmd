stateDiagram-v2
    direction TB
    [*] --> q_init: deposit_requests = b""
    q_init --> q_iter_keys: for key in block_output.receipt_keys
    q_iter_keys --> q_get_receipt: has next key
    q_get_receipt --> q_decode: receipt = trie_get(block_output.receipts_trie, key)
    q_decode --> q_iter_logs: decoded_receipt = decode_receipt(receipt)
    q_iter_logs --> q_check_addr: for log in decoded_receipt.logs
    q_check_addr --> q_check_topic: log.address == DEPOSIT_CONTRACT_ADDRESS
    q_check_addr --> q_iter_logs: log.address != DEPOSIT_CONTRACT_ADDRESS
    q_check_topic --> q_extract: len(log.topics) > 0 AND log.topics[0] == DEPOSIT_EVENT_SIGNATURE_HASH
    q_check_topic --> q_iter_logs: topic check fails
    q_extract --> q_append: request = extract_deposit_data(log.data)
    q_append --> q_iter_logs: deposit_requests += request
    q_iter_logs --> q_iter_keys: no more logs
    q_iter_keys --> [*]: no more keys, return deposit_requests
