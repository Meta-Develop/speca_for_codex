stateDiagram-v2
    direction TB
    [*] --> q_read_h: h = input[0..32] (BigEndian)
    q_read_h --> q_read_r: r = input[32..64] (BigEndian)
    q_read_r --> q_read_s: s = input[64..96] (BigEndian)
    q_read_s --> q_read_qx: qx = input[96..128] (BigEndian)
    q_read_qx --> q_read_qy: qy = input[128..160] (BigEndian)
    q_read_qy --> [*]: return (h, r, s, qx, qy)
