stateDiagram-v2
    direction TB
    [*] --> q_mod_inv: s1 = s^(-1) (mod n)
    q_mod_inv --> q_scalar1: u1 = h * s1 (mod n)
    q_scalar1 --> q_scalar2: u2 = r * s1 (mod n)
    q_scalar2 --> q_ecmul1: P1 = u1 * G
    q_ecmul1 --> q_ecmul2: P2 = u2 * (qx, qy)
    q_ecmul2 --> q_ecadd: R_prime = P1 + P2
    q_ecadd --> q_check_inf: R_prime == point at infinity
    q_check_inf --> q_fail_inf: R_prime is point at infinity
    q_check_inf --> q_extract_x: R_prime is not point at infinity
    q_fail_inf --> [*]: return false
    q_extract_x --> q_compare: r_prime = R_prime.x
    q_compare --> q_success: r_prime == r (mod n)
    q_compare --> q_fail_cmp: r_prime != r (mod n)
    q_success --> [*]: return true
    q_fail_cmp --> [*]: return false
