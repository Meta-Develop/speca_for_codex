stateDiagram-v2
    direction TB
    [*] --> q_check_bounds_x: 0 <= qx < p
    q_check_bounds_x --> q_fail_bounds: qx >= p
    q_check_bounds_x --> q_check_bounds_y: qx in range
    q_fail_bounds --> [*]: return false
    q_check_bounds_y --> q_fail_bounds_y: qy >= p
    q_check_bounds_y --> q_compute_lhs: qy in range
    q_fail_bounds_y --> [*]: return false
    q_compute_lhs --> q_compute_rhs: lhs = qy^2 (mod p)
    q_compute_rhs --> q_compare: rhs = qx^3 + a*qx + b (mod p)
    q_compare --> q_on_curve: lhs == rhs
    q_compare --> q_not_on_curve: lhs != rhs
    q_not_on_curve --> [*]: return false
    q_on_curve --> q_check_inf: point is on curve
    q_check_inf --> q_is_inf: (qx, qy) == (0, 0)
    q_check_inf --> q_valid: (qx, qy) != (0, 0)
    q_is_inf --> [*]: return false
    q_valid --> [*]: return true
