stateDiagram-v2
    direction TB
    [*] --> q_version: fork_version = compute_fork_version(epoch)
    q_version --> q_base: base_digest = compute_fork_data_root(fork_version, genesis_validators_root)
    q_base --> q_blob: blob_parameters = get_blob_parameters(epoch)
    q_blob --> q_hash: h = hash(uint_to_bytes(blob_parameters.epoch) + uint_to_bytes(blob_parameters.max_blobs_per_block))
    q_hash --> q_xor: result = xor(base_digest, h)
    q_xor --> [*]: return ForkDigest(bytes(result)[:4])
