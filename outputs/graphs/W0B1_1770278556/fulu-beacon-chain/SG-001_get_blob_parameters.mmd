stateDiagram-v2
    direction TB
    [*] --> q_sort: sorted_schedule = sorted(BLOB_SCHEDULE, key=epoch, reverse=True)
    q_sort --> q_iter: for entry in sorted_schedule
    q_iter --> q_check: has_next_entry
    q_check --> q_return_entry: epoch >= entry.EPOCH
    q_check --> q_iter: epoch < entry.EPOCH
    q_iter --> q_default: no_more_entries
    q_default --> [*]: return BlobParameters(ELECTRA_FORK_EPOCH, MAX_BLOBS_PER_BLOCK_ELECTRA)
    q_return_entry --> [*]: return BlobParameters(entry.EPOCH, entry.MAX_BLOBS_PER_BLOCK)
