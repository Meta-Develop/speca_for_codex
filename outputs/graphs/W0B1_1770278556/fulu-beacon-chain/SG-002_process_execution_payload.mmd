stateDiagram-v2
    direction TB
    [*] --> q_extract: payload = body.execution_payload
    q_extract --> q_check_parent: assert payload.parent_hash == state.latest_execution_payload_header.block_hash
    q_check_parent --> q_check_randao: assert payload.prev_randao == get_randao_mix(state, get_current_epoch(state))
    q_check_randao --> q_check_time: assert payload.timestamp == compute_time_at_slot(state, state.slot)
    q_check_time --> q_check_blobs: assert len(body.blob_kzg_commitments) <= get_blob_parameters(epoch).max_blobs_per_block
    q_check_blobs --> q_compute_hashes: versioned_hashes = [kzg_commitment_to_versioned_hash(c) for c in body.blob_kzg_commitments]
    q_compute_hashes --> q_verify_payload: assert execution_engine.verify_and_notify_new_payload(NewPayloadRequest(...))
    q_verify_payload --> q_cache_header: state.latest_execution_payload_header = ExecutionPayloadHeader(...)
    q_cache_header --> [*]: return
