stateDiagram-v2
    direction TB
    [*] --> q_unpack: block = signed_block.message
    q_unpack --> q_check_parent: block.parent_root in store.block_states
    q_unpack --> q_abort: block.parent_root not in store.block_states
    q_check_parent --> q_copy_state: state = copy(store.block_states[block.parent_root])
    q_copy_state --> q_check_slot: get_current_slot(store) >= block.slot
    q_copy_state --> q_abort: get_current_slot(store) < block.slot
    q_check_slot --> q_compute_fin_slot: finalized_slot = compute_start_slot_at_epoch(store.finalized_checkpoint.epoch)
    q_compute_fin_slot --> q_check_fin_slot: block.slot > finalized_slot
    q_compute_fin_slot --> q_abort: block.slot <= finalized_slot
    q_check_fin_slot --> q_get_checkpoint: finalized_checkpoint_block = get_checkpoint_block(store, block.parent_root, store.finalized_checkpoint.epoch)
    q_get_checkpoint --> q_check_fin_root: store.finalized_checkpoint.root == finalized_checkpoint_block
    q_get_checkpoint --> q_abort: store.finalized_checkpoint.root != finalized_checkpoint_block
    q_check_fin_root --> q_check_data: is_data_available(hash_tree_root(block))
    q_check_fin_root --> q_abort: not is_data_available(hash_tree_root(block))
    q_check_data --> q_compute_root: block_root = hash_tree_root(block)
    q_compute_root --> q_run_transition: state_transition(state, signed_block, True)
    q_run_transition --> q_store_block: store.blocks[block_root] = block
    q_store_block --> q_store_state: store.block_states[block_root] = state
    q_store_state --> q_record: record_block_timeliness(store, block_root)
    q_record --> q_boost: update_proposer_boost_root(store, block_root)
    q_boost --> q_update_cp: update_checkpoints(store, state.current_justified_checkpoint, state.finalized_checkpoint)
    q_update_cp --> q_pullup: compute_pulled_up_tip(store, block_root)
    q_pullup --> [*]: return
    q_abort --> [*]: raise AssertionError
