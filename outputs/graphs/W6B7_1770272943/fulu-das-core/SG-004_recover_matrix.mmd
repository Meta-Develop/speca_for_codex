stateDiagram-v2
    direction TB
    [*] --> q_init: matrix = []
    q_init --> q_iter_blob: for blob_index in range(blob_count)
    q_iter_blob --> q_filter: has next blob_index
    q_iter_blob --> q_return: no more blob indices
    q_filter --> q_recover: cell_indices = filter(partial_matrix, blob_index), cells = filter(partial_matrix, blob_index)
    q_recover --> q_iter_cell: recovered_cells, recovered_proofs = recover_cells_and_kzg_proofs(cell_indices, cells)
    q_iter_cell --> q_append: has next recovered cell
    q_iter_cell --> q_iter_blob: no more recovered cells
    q_append --> q_iter_cell: matrix.append(MatrixEntry(cell, proof, cell_index, blob_index))
    q_return --> [*]: return matrix
