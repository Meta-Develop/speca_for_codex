stateDiagram-v2
    direction TB
    [*] --> q_validate: assert custody_group_count <= NUMBER_OF_CUSTODY_GROUPS
    q_validate --> q_check_all: custody_group_count == NUMBER_OF_CUSTODY_GROUPS
    q_validate --> q_init_loop: custody_group_count != NUMBER_OF_CUSTODY_GROUPS
    q_check_all --> [*]: return [CustodyIndex(i) for i in range(NUMBER_OF_CUSTODY_GROUPS)]
    q_init_loop --> q_loop: current_id = uint256(node_id), custody_groups = []
    q_loop --> q_hash: len(custody_groups) < custody_group_count
    q_loop --> q_assert: len(custody_groups) >= custody_group_count
    q_hash --> q_check_dup: custody_group = hash(current_id)[0..8] % NUMBER_OF_CUSTODY_GROUPS
    q_check_dup --> q_append: custody_group not in custody_groups
    q_check_dup --> q_inc: custody_group in custody_groups
    q_append --> q_inc: custody_groups.append(custody_group)
    q_inc --> q_overflow: current_id == UINT256_MAX
    q_inc --> q_loop: current_id = current_id + 1
    q_overflow --> q_loop: current_id = 0
    q_assert --> [*]: return sorted(custody_groups)
