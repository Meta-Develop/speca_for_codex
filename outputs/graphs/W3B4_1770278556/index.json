    {
      "source_url": "https://github.com/ethereum/execution-specs/blob/forks/amsterdam/src/ethereum/forks/osaka/bloom.py",
      "title": "Osaka Bloom Filter",
      "sub_graphs": [
        {
          "id": "SG-001",
          "name": "add_to_bloom",
          "mermaid_file": "osaka-bloom/SG-001_add_to_bloom.mmd",
          "program_graph": {
            "Q": ["q_init", "q_hash", "q_iter", "q_extract", "q_bit_set", "q_bit_index", "q_byte_index", "q_bit_value", "q_update", "q_final"],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
              "hashed = keccak256(bloom_entry)",
              "idx = 0",
              "idx in (0, 2, 4)",
              "bit_to_set = Uint.from_be_bytes(hashed[idx:idx+2]) AND 0x07FF",
              "bit_index = 0x07FF - int(bit_to_set)",
              "byte_index = bit_index // 8",
              "bit_value = 1 << (7 - (bit_index % 8))",
              "bloom[byte_index] = bloom[byte_index] | bit_value",
              "idx = next(idx)",
              "idx exhausted"
            ],
            "E": [
              ["q_init", "hashed = keccak256(bloom_entry)", "q_hash"],
              ["q_hash", "idx = 0", "q_iter"],
              ["q_iter", "idx in (0, 2, 4)", "q_extract"],
              ["q_extract", "bit_to_set = Uint.from_be_bytes(hashed[idx:idx+2]) AND 0x07FF", "q_bit_set"],
              ["q_bit_set", "bit_index = 0x07FF - int(bit_to_set)", "q_bit_index"],
              ["q_bit_index", "byte_index = bit_index // 8", "q_byte_index"],
              ["q_byte_index", "bit_value = 1 << (7 - (bit_index % 8))", "q_bit_value"],
              ["q_bit_value", "bloom[byte_index] = bloom[byte_index] | bit_value", "q_update"],
              ["q_update", "idx = next(idx)", "q_iter"],
              ["q_iter", "idx exhausted", "q_final"]
            ]
          },
          "invariants": [
            "INV-001: bloom bytearray must be exactly 256 bytes",
            "INV-002: bit_to_set is always in range [0, 2047] (11-bit mask 0x07FF)",
            "INV-003: byte_index is always in range [0, 255]",
            "INV-004: The loop iterates exactly 3 times (indices 0, 2, 4), setting 3 bits per bloom entry",
            "INV-005: keccak256 output is at least 6 bytes to support 3 pairs of 2-byte reads"
          ]
        },
        {
          "id": "SG-002",
          "name": "logs_bloom",
          "mermaid_file": "osaka-bloom/SG-002_logs_bloom.mmd",
          "program_graph": {
            "Q": ["q_init", "q_iter_logs", "q_add_addr", "q_iter_topics", "q_add_topic", "q_return", "q_final"],
            "q_init": "q_init",
            "q_final": "q_final",
            "Act": [
              "bloom = bytearray(256 zero bytes)",
              "for log in logs",
              "has next log",
              "add_to_bloom(bloom, log.address)",
              "for topic in log.topics",
              "add_to_bloom(bloom, topic)",
              "topics exhausted",
              "logs exhausted",
              "return Bloom(bloom)"
            ],
            "E": [
              ["q_init", "bloom = bytearray(256 zero bytes)", "q_iter_logs"],
              ["q_iter_logs", "has next log", "q_add_addr"],
              ["q_add_addr", "add_to_bloom(bloom, log.address)", "q_iter_topics"],
              ["q_iter_topics", "for topic in log.topics", "q_add_topic"],
              ["q_add_topic", "add_to_bloom(bloom, topic)", "q_iter_topics"],
              ["q_iter_topics", "topics exhausted", "q_iter_logs"],
              ["q_iter_logs", "logs exhausted", "q_return"],
              ["q_return", "return Bloom(bloom)", "q_final"]
            ]
          },
          "invariants": [
            "INV-001: bloom is initialized to all zeros (256 bytes)",
            "INV-002: Every log address is added to the bloom filter exactly once",
            "INV-003: Every topic of every log is added to the bloom filter exactly once",
            "INV-004: The returned Bloom is constructed from the mutated bytearray after all logs are processed",
            "INV-005: add_to_bloom is called (1 + len(log.topics)) times per log entry"
          ]
        }
      ]
    }
