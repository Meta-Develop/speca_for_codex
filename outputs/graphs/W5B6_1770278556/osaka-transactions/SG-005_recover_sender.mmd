---
title: recover_sender (osaka/transactions.py)
---
stateDiagram-v2
    direction TB

    [*] --> q_init
    q_init --> q_extract_rs : r, s = tx.r, tx.s
    q_extract_rs --> q_check_r : validate r range
    q_check_r --> q_error_r : 0 >= r or r >= SECP256K1N
    q_check_r --> q_check_s : r valid
    q_error_r --> q_final : raise InvalidSignatureError
    q_check_s --> q_error_s : 0 >= s or s > SECP256K1N / 2
    q_check_s --> q_check_type : s valid
    q_error_s --> q_final : raise InvalidSignatureError
    q_check_type --> q_legacy : tx is LegacyTransaction
    q_check_type --> q_typed : tx is typed transaction
    q_legacy --> q_recover_pre155 : v == 27 or v == 28
    q_legacy --> q_recover_155 : v is EIP-155 encoded
    q_legacy --> q_error_v : v is invalid
    q_error_v --> q_final : raise InvalidSignatureError
    q_recover_pre155 --> q_address : secp256k1_recover(r, s, v-27, signing_hash_pre155(tx))
    q_recover_155 --> q_address : secp256k1_recover(r, s, v-35-chain_id*2, signing_hash_155(tx))
    q_typed --> q_check_parity : validate y_parity
    q_check_parity --> q_error_parity : y_parity not in (0, 1)
    q_check_parity --> q_recover_typed : parity valid
    q_error_parity --> q_final : raise InvalidSignatureError
    q_recover_typed --> q_address : secp256k1_recover(r, s, y_parity, signing_hash_<type>(tx))
    q_address --> q_final : return Address(keccak256(public_key)[12:32])
    q_final --> [*]

    note right of q_check_r
        INV-001: 0 < r < SECP256K1N
        INV-002: 0 < s <= SECP256K1N / 2 (low-s)
        INV-003: Legacy uses v; typed uses y_parity
        INV-004: Each tx type has its own signing hash
    end note
