stateDiagram-v2
    direction TB
    [*] --> q_calc_mult: multiplication_complexity = calculate_multiplication_complexity(base_length, modulus_length)
    q_calc_mult --> q_calc_iter: iteration_count = calculate_iteration_count(exponent_length, exponent)
    q_calc_iter --> q_compute_cost: cost = floor(multiplication_complexity * iteration_count)
    q_compute_cost --> q_check_min: check cost >= 500
    q_check_min --> q_return_cost: cost >= 500
    q_check_min --> q_return_min: cost < 500
    q_return_cost --> [*]: return cost
    q_return_min --> [*]: return 500
