stateDiagram-v2
    direction TB
    [*] --> q_init: iteration_count = 0
    q_init --> q_check_exp_len: check exponent_length
    q_check_exp_len --> q_check_exp_zero: exponent_length <= 32
    q_check_exp_len --> q_large_exp: exponent_length > 32
    q_check_exp_zero --> q_clamp: exponent == 0
    q_check_exp_zero --> q_small_exp: exponent != 0
    q_clamp --> q_return: iteration_count = max(0, 1)
    q_small_exp --> q_return: iteration_count = max(exponent.bit_length() - 1, 1)
    q_large_exp --> q_return: iteration_count = max((16 * (exponent_length - 32)) + ((exponent AND (2**256 - 1)).bit_length() - 1), 1)
    q_return --> [*]: return iteration_count
