      },
      "invariants": [
        "INV-001: Gas cost >= 500 for all inputs (minimum floor)",
        "INV-002: Gas cost is not divided by 3 (change from EIP-2565)",
        "INV-003: Gas cost = max(500, floor(multiplication_complexity * iteration_count))"
