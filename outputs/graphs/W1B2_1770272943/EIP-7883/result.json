        "q_init": "q_init",
        "q_final": "q_final",
        "Act": [
          "iteration_count = 0",
          "exponent_length <= 32",
          "exponent_length > 32",
          "exponent == 0",
          "exponent != 0",
          "iteration_count = max(0, 1)",
          "iteration_count = max(exponent.bit_length() - 1, 1)",
          "iteration_count = max((16 * (exponent_length - 32)) + ((exponent AND (2**256 - 1)).bit_length() - 1), 1)",
          "return iteration_count"
        ],
        "E": [
