          ["q_check_exp_zero", "exponent == 0", "q_clamp"],
          ["q_check_exp_zero", "exponent != 0", "q_small_exp"],
          ["q_clamp", "iteration_count = max(0, 1)", "q_return"],
          ["q_small_exp", "iteration_count = max(exponent.bit_length() - 1, 1)", "q_return"],
          ["q_large_exp", "iteration_count = max((16 * (exponent_length - 32)) + ((exponent AND (2**256 - 1)).bit_length() - 1), 1)", "q_return"],
          ["q_return", "return iteration_count", "q_final"]
        ]
      },
      "invariants": [
        "INV-001: iteration_count >= 1 for all non-trivial inputs",
        "INV-002: If exponent_length <= 32 and exponent == 0 then iteration_count == 1",
        "INV-003: The multiplier for large exponents is 16 (doubled from EIP-2565 value of 8)"
      ]
    },
